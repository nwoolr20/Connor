# Connor Multi-Agent System Environment Configuration
# ================================================

# System Configuration
CONNOR_ENV=development
CONNOR_DEBUG=false
CONNOR_LOG_LEVEL=INFO

# AI Model Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# LiteLLM Configuration
LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_MODEL=gpt-4
LITELLM_LOG_LEVEL=INFO

# Memory System Configuration
CHROMA_DB_PATH=./chroma_db
MEMORY_BACKEND=chromadb
MEMORY_EMBEDDING_MODEL=text-embedding-ada-002
MEMORY_COLLECTION_NAME=connor_memory

# Agent Configuration
MAX_AGENTS=20
AGENT_TIMEOUT=30
AGENT_RETRY_ATTEMPTS=3
AGENT_MEMORY_SIZE=1000

# Communication Configuration
MESSAGE_QUEUE_SIZE=100
COMMUNICATION_TIMEOUT=10

# Performance Configuration
PARALLEL_PROCESSING=true
MAX_CONCURRENT_AGENTS=5
PERFORMANCE_MONITORING=true

# Security Configuration
ENABLE_SECURITY_AUDIT=true
MAX_REQUEST_SIZE=10MB
RATE_LIMIT=100

# Development Configuration
DEV_MODE=false
AUTO_RELOAD=false
PROFILING_ENABLED=false

# Logging Configuration
LOG_FILE=./logs/connor.log
LOG_ROTATION=daily
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=7

# Database Configuration (if using SQL backend)
DATABASE_URL=sqlite:///connor.db
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30

# Web Interface Configuration (if enabled)
WEB_HOST=localhost
WEB_PORT=8000
WEB_DEBUG=false

# Example API Keys (replace with actual values)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Monitoring and Alerts
MONITORING_ENABLED=true
ALERT_EMAIL=admin@yourdomain.com
HEALTH_CHECK_INTERVAL=60

# Advanced Features
EXPERIMENTAL_FEATURES=false
PLUGIN_SYSTEM_ENABLED=false
CUSTOM_AGENT_LOADING=false