################################################################################
### Connor-AutoGPT - INTEGRATED SYSTEM CONFIGURATION
################################################################################

## OPENAI_API_KEY - Required for Connor's multi-agent system
OPENAI_API_KEY=your-openai-api-key

## Connor System Configuration
CONNOR_ENABLED=true
CONNOR_AGENT_COUNT=13
CONNOR_LOG_LEVEL=INFO

## AutoGPT Configuration
AI_NAME=Connor
AI_ROLE=Multi-Agent AI Assistant powered by Connor's sophisticated agent system
AI_GOALS=Provide intelligent assistance using a coordinated team of specialized AI agents

## Telemetry and Privacy
TELEMETRY_OPT_IN=false

## Security Settings
EXECUTE_LOCAL_COMMANDS=false
RESTRICT_TO_WORKSPACE=true

## File Storage
FILE_STORAGE_BACKEND=local

## Browser and Web Access
SELENIUM_WEB_BROWSER=chrome
HEADLESS_BROWSER=true

## Command Categories
DISABLED_COMMAND_CATEGORIES=

## Connor Multi-Agent Pipeline Configuration
CONNOR_SRA_COUNT=3
CONNOR_MBR_COUNT=2  
CONNOR_GAP_COUNT=2
CONNOR_LA_COUNT=4
CONNOR_UBA_COUNT=1
CONNOR_AA_COUNT=1

## Learning and Memory
CONNOR_MEMORY_SIZE=1000
CONNOR_LEARNING_ENABLED=true

## Performance Settings
CONNOR_MAX_CONCURRENT_AGENTS=5
CONNOR_PROCESSING_TIMEOUT=30

################################################################################
### ADVANCED SETTINGS
################################################################################

## LLM Provider Settings for Connor
LLM_PROVIDER=openai
TEMPERATURE=0.7
MAX_TOKENS=2000

## Connor System Metrics
CONNOR_METRICS_ENABLED=true
CONNOR_PERFORMANCE_MONITORING=true

## Debug Mode
DEBUG=false
LOG_LEVEL=INFO